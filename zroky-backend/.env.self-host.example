# Zroky self-host environment — copy to .env.self-host and fill in real values.
# Lines starting with # are comments. DO NOT commit .env.self-host to git.

APP_NAME=zroky-backend
# Local docker-compose self-host profile. Use .env.production.example and set
# APP_ENV=production when deploying with real domains and strict production gates.
APP_ENV=self-host
LOG_LEVEL=INFO
LOG_FORMAT=json
PORT=8000

# Required services. docker-compose may inject these; set them explicitly for
# non-compose self-host installs.
DATABASE_URL=postgresql+psycopg://zroky:__SET_IN_SECRET_MANAGER__@postgres:5432/zroky
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_STORAGE_URI=

# ── Required: Auth ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=__SET_IN_SECRET_MANAGER__
AUTH_JWT_EXPIRE_HOURS=72
AUTH_REFRESH_TOKEN_EXPIRE_HOURS=720
AUTH_BCRYPT_ROUNDS=12
OAUTH_STATE_SECRET=__SET_IN_SECRET_MANAGER__

# ── Required: Encryption ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PII_ENCRYPTION_KEY=__SET_IN_SECRET_MANAGER__
PII_HMAC_KEY=__SET_IN_SECRET_MANAGER__
PROVIDER_KEY_VAULT_KEK=__SET_IN_SECRET_MANAGER__
PROVIDER_KEY_VAULT_KEY_ID=self-host-kek-v1

# ── Provider keys — BYOK default ─────────────────────────────────────────────
# Signup / capture / traces / issues / stub replay work WITHOUT a provider key.
# Set these only if you want real replay / judge / drift-watch on your own infra.
# Customers can configure their own keys through the dashboard (stored encrypted).
# OPENAI_API_KEY=__SET_IN_SECRET_MANAGER__
# ANTHROPIC_API_KEY=__SET_IN_SECRET_MANAGER__
# GOOGLE_API_KEY=__SET_IN_SECRET_MANAGER__
# OPENROUTER_API_KEY=__SET_IN_SECRET_MANAGER__
# AZURE_OPENAI_API_KEY=__SET_IN_SECRET_MANAGER__

# Optional billing and notifications. Leave billing disabled unless you are
# running a hosted Skydo payment-link flow for this deployment.
BILLING_PROVIDER=skydo
SKYDO_PAYMENT_INSTRUCTIONS_URL=https://dashboard.skydo.com/
SKYDO_PORTAL_URL=https://dashboard.skydo.com/
# SKYDO_PAYMENT_LINK_TEMPLATE=
# SKYDO_WEBHOOK_SECRET=__SET_IN_SECRET_MANAGER__
# SLACK_CLIENT_ID=__SET_IN_SECRET_MANAGER__
# SLACK_CLIENT_SECRET=__SET_IN_SECRET_MANAGER__
# Legacy/global Slack webhook only; not required for per-tenant Slack Settings installs.
# SLACK_WEBHOOK_URL=__SET_IN_SECRET_MANAGER__
# SLACK_TOKEN_ENCRYPTION_KEY=__SET_IN_SECRET_MANAGER__
# SLACK_SIGNING_SECRET=__SET_IN_SECRET_MANAGER__
# SMTP_HOST=
# SMTP_USER=__SET_IN_SECRET_MANAGER__
# SMTP_PASSWORD=__SET_IN_SECRET_MANAGER__

# ── Optional: GitHub OAuth (social login) ────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URL=http://localhost:3000/auth/github/callback

# ── Optional: Google OAuth (social login) ────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/v1/auth/google/callback

# ── Optional: GitHub integration (for fix PRs) ───────────────────────────────
# GITHUB_PR_BOT_TOKEN=__SET_IN_SECRET_MANAGER__
# GITHUB_TOKEN_ENCRYPTION_KEY=__SET_IN_SECRET_MANAGER__
# GITHUB_PR_DEFAULT_OWNER=your-org
# GITHUB_PR_DEFAULT_REPO=your-repo

# ── Optional: Replay worker ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REPLAY_WORKER_TOKEN=__SET_IN_SECRET_MANAGER__
# ARTIFACT_SIGNING_KEY=__SET_IN_SECRET_MANAGER__

# ── Optional: Provisioning ───────────────────────────────────────────────────
REQUIRE_PROVISIONING_TOKEN=false
PROVISIONING_TOKEN_HEADER_NAME=x-zroky-admin-token
# PROVISIONING_TOKEN=__SET_IN_SECRET_MANAGER__

# ── Security: CORS + trusted hosts ───────────────────────────────────────────
# Comma-separated. Set to your actual domain in non-localhost deployments.
ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000
TENANT_HEADER_NAME=x-project-id
LEGACY_TENANT_HEADER_NAME=x-tenant-id
ACCEPT_LEGACY_TENANT_HEADER=false
API_KEY_HEADER_NAME=x-api-key
ACCEPT_BEARER_AS_API_KEY=true

# ── Optional: Feature flags ───────────────────────────────────────────────────
ALLOW_PROJECT_HEADER_CONTEXT=false
FEATURE_LEGACY_OWNER=false
FEATURE_LEGACY_BILLING=false
FEATURE_LEGACY_INVITATIONS=true
FEATURE_LEGACY_DIAGNOSIS_ALIAS=true

# ── Optional: ClickHouse analytics (W12) ─────────────────────────────────────
# Set to true and provide URL to enable ClickHouse-backed /cost and /issues.
# Without this, both endpoints fall back gracefully to Postgres.
# CLICKHOUSE_ENABLED=true
# CLICKHOUSE_URL=http://clickhouse:8123
# CLICKHOUSE_DATABASE=zroky
# CLICKHOUSE_USER=zroky
# CLICKHOUSE_PASSWORD=__SET_IN_SECRET_MANAGER__
CLICKHOUSE_SYNC_INTERVAL_SECONDS=60

# ── Optional: Billing quota enforcement ───────────────────────────────────────
# When true, ingest returns HTTP 429 once a tenant exceeds plan's
# max_calls_per_month. Off by default — enable after setting up plans.
# BILLING_ENFORCE_QUOTA=false

# ── Computed by docker-compose (do not change) ───────────────────────────────
# DATABASE_URL and REDIS_URL are injected by docker-compose
# PORT is set by docker-compose

# Advanced launch knobs. Defaults mirror app.core.config.Settings.
ENABLE_READY_DB_CHECK=true
ENABLE_READY_REDIS_CHECK=true
ENABLE_METRICS_ENDPOINT=true
METRICS_TOKEN_HEADER_NAME=x-zroky-metrics-token
METRICS_TOKEN=__SET_IN_SECRET_MANAGER__
ENABLE_INTERNAL_DEBUG_ENDPOINT=false
INTERNAL_DEBUG_TOKEN_HEADER_NAME=x-zroky-internal-token
INTERNAL_DEBUG_TOKEN=__SET_IN_SECRET_MANAGER__
IDEMPOTENCY_TTL_SECONDS=600
DIAGNOSIS_TASK_MAX_RETRIES=3
DIAGNOSIS_TASK_RETRY_BASE_SECONDS=2
DIAGNOSIS_TASK_RETRY_MAX_SECONDS=30
READ_ONLY_SHARE_TOKEN_TTL_SECONDS=86400
RETENTION_ENFORCEMENT_ENABLED=true
RETENTION_ENFORCEMENT_CRON_MINUTE=0
RETENTION_ENFORCEMENT_CRON_HOUR=3
RETENTION_PURGE_BATCH_SIZE=500
RETENTION_PURGE_DRY_RUN=false
INGEST_ENFORCE_RATE_LIMIT=true
INGEST_SOFT_LIMIT_RPM=120
INGEST_BURST_LIMIT_RPM=240
INGEST_RATE_LIMIT_WINDOW_SECONDS=60
INGEST_SUSTAINED_BREACH_THRESHOLD=3
INGEST_BACKPRESSURE_TTL_SECONDS=300
GATEWAY_INGEST_STREAM_ENABLED=false
GATEWAY_INGEST_STREAM_NAME=zroky:ingest:v2
GATEWAY_INGEST_CONSUMER_GROUP=zroky-backend
GATEWAY_INGEST_CONSUMER_NAME=worker-1
GATEWAY_INGEST_STREAM_BATCH_SIZE=100
GATEWAY_INGEST_STREAM_BLOCK_MS=1000
GATEWAY_INGEST_POLL_INTERVAL_SECONDS=5
PROVIDER_STATUS_FETCH_TIMEOUT_MS=800
PROVIDER_STATUS_CACHE_TTL_SECONDS=300
PROVIDER_STATUS_ENDPOINTS_JSON={}
OPENROUTER_PRIMARY_MODEL=deepseek/deepseek-chat
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat-v3
OPENROUTER_ASSISTANT_MODEL=google/gemini-2.5-flash
OPENROUTER_ANALYTICS_MODEL=openai/gpt-4o-mini
OPENROUTER_REQUEST_TIMEOUT_SECONDS=60
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=
JWT_SIGNING_KEY=
JWT_ALGORITHMS=RS256
JWT_PROJECT_CLAIM=project_id
JWT_PROJECTS_CLAIM=projects
JWT_ROLES_CLAIM=roles
JWT_ADMIN_ROLE=zroky_admin
ALLOW_JWT_PROVISIONING_ACCESS=true
ENFORCE_JWT_PROJECT_MEMBERSHIP=true
DATABASE_READ_REPLICA_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_STATEMENT_TIMEOUT_MS=30000
DEPLOY_TARGET=self-host
APP_DOMAIN=localhost
SECURITY_CONTACT_EMAIL=security@zroky.com
SECURITY_PGP_KEY_URL=https://zroky.com/pgp-key.txt
REPLAY_REAL_LLM_ENABLED=false
REPLAY_REAL_LLM_BUDGET_USD=1.00
REPLAY_SANDBOX_WORKER_URL=
REPLAY_SANDBOX_WORKER_TOKEN=__SET_IN_SECRET_MANAGER__
REPLAY_SANDBOX_TIMEOUT_SECONDS=30
BILLING_ENABLED=false
BILLING_ENFORCE_QUOTA=false
BILLING_CHECKOUT_SUCCESS_URL=http://localhost:3000/settings/billing?checkout=success
BILLING_CHECKOUT_CANCEL_URL=http://localhost:3000/settings/billing?checkout=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:3000/settings/billing
BILLING_LIFECYCLE_SWEEP_ENABLED=true
BILLING_PAST_DUE_GRACE_DAYS=7
BILLING_LIFECYCLE_SWEEP_LIMIT=500
BILLING_LIFECYCLE_SWEEP_MINUTE=7
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/v1/auth/google/callback
GITHUB_CONNECT_OAUTH_REDIRECT_URL=http://localhost:3000/auth/github/connect/callback
GITHUB_REPO_OAUTH_SCOPES=repo read:user user:email
GITHUB_PR_DEFAULT_BASE_BRANCH=main
GITHUB_WEBHOOK_SECRET=__SET_IN_SECRET_MANAGER__
SMTP_PORT=587
SMTP_USE_TLS=true
ALERTS_FROM_EMAIL=noreply@zroky.com
SLACK_OAUTH_REDIRECT_URL=http://localhost:8000/v1/integrations/slack/callback
SLACK_OAUTH_SCOPES=incoming-webhook,chat:write,commands,channels:read,groups:read
# MS_TEAMS_WEBHOOK_ENCRYPTION_KEY=__SET_IN_SECRET_MANAGER__
DIGEST_ENABLED=false
DIGEST_SEND_BATCH_SIZE=100
DIGEST_GENERATE_CRON_DAY_OF_WEEK=1
DIGEST_GENERATE_CRON_HOUR=2
PROVIDER_DRIFT_WATCH_ENABLED=true
PROVIDER_DRIFT_WATCH_CRON_HOUR=4
PROVIDER_DRIFT_WATCH_CRON_MINUTE=0
PROVIDER_DRIFT_WATCH_BUDGET_USD=10.0
PROVIDER_DRIFT_WATCH_Z_INFO=2.0
PROVIDER_DRIFT_WATCH_Z_WARN=3.0
PROVIDER_DRIFT_WATCH_Z_CRITICAL=4.0
