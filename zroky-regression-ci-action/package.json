{
  "name": "zroky-regression-ci-action",
  "version": "1.0.0",
  "description": "GitHub Action for Zroky Pre-deploy Replay CI Gate",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build lib/main.js -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "all": "npm run build && npm run package && npm test"
  },
  "keywords": ["zroky", "replay", "ci", "regression", "ai-observability"],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "2.0.0",
    "@actions/github": "8.0.1",
    "@actions/http-client": "3.0.2"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
