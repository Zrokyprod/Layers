# Copy to .env, then paste values from Zroky dashboard -> Settings -> API Keys.

ZROKY_API_KEY=zk_live_your_key_here
ZROKY_PROJECT=proj_your_project_id

# Optional dashboard alias. agent.py maps this to ZROKY_PROJECT when needed.
ZROKY_PROJECT_ID=proj_your_project_id

# SDK API base. Use your backend URL if you are testing a non-production environment.
ZROKY_INGEST_URL=https://api.zroky.com

ZROKY_AGENT_NAME=Manual QA Agent
ZROKY_AGENT_ID=
ZROKY_AGENT_FRAMEWORK=Custom Python
ZROKY_ENVIRONMENT=development
