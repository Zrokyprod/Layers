CONTROL_PLANE_URL=https://api.zroky.com
WORKER_TOKEN=__SET_IN_SECRET_MANAGER__
ARTIFACT_SIGNING_KEY=__SET_IN_SECRET_MANAGER__
POLL_INTERVAL_SECONDS=10
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_SECONDS=300
LOG_LEVEL=INFO

# ── Provider keys — BYOK ─────────────────────────────────────────────────────
# These are used only for real/verified replay jobs.
# The worker receives the customer's decrypted key from the backend control-plane.
# Set platform-side fallback keys only if Zroky operates managed replay.
