PORT=8090
REDIS_URL=redis://localhost:6379
REDIS_STREAM=zroky:ingest:v2
ZROKY_EMIT_MODE=redis
ZROKY_API_URL=https://api.zroky.com
ZROKY_INGEST_URL=https://api.zroky.com/api/v1/ingest
# Customer project key — set this to the project's ZROKY_API_KEY
ZROKY_GATEWAY_API_KEY=__SET_IN_SECRET_MANAGER__
ZROKY_GATEWAY_AUTH_TOKEN=__SET_IN_SECRET_MANAGER__
ZROKY_ALLOWED_PROJECT_IDS=__SET_IN_SECRET_MANAGER__
ZROKY_WORKFLOW_NAME=support-resolution
ZROKY_PROMPT_VERSION=support-v42
ZROKY_SPOOL_DIR=.zroky-spool
ZROKY_SPOOL_MAX_BYTES=104857600
ZROKY_SPOOL_FLUSH_INTERVAL_MS=5000
ZROKY_SPOOL_RESERVE_BYTES=8388608
ZROKY_SPOOL_HIGH_WATERMARK_RATIO=0.85
ZROKY_CAPTURE_DURABILITY_MODE=fail_closed
ZROKY_GATEWAY_ID=gateway-prod-1
ZROKY_GATEWAY_HEARTBEAT_INTERVAL_MS=30000
ZROKY_GATEWAY_HEARTBEAT_URL=http://localhost:8000/api/v1/capture/gateway-heartbeat

# ── Provider keys — BYOK ─────────────────────────────────────────────────────
# Gateway proxies provider API calls on behalf of the customer.
# Set these to the customer's own keys. Zroky does not provide shared provider keys.
# OPENAI_API_KEY=__SET_IN_SECRET_MANAGER__
# ANTHROPIC_API_KEY=__SET_IN_SECRET_MANAGER__
# GOOGLE_API_KEY=__SET_IN_SECRET_MANAGER__
# OPENROUTER_API_KEY=__SET_IN_SECRET_MANAGER__
# AZURE_OPENAI_API_KEY=__SET_IN_SECRET_MANAGER__

OPENAI_UPSTREAM_BASE_URL=https://api.openai.com
ANTHROPIC_UPSTREAM_BASE_URL=https://api.anthropic.com
GOOGLE_UPSTREAM_BASE_URL=https://generativelanguage.googleapis.com
MAX_BODY_BYTES=4194304
LOG_LEVEL=info
PRETTY_LOGS=false
READ_TIMEOUT=30s
WRITE_TIMEOUT=60s
IDLE_TIMEOUT=120s
