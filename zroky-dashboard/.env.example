ZROKY_API_BASE_URL=https://api.zroky.com
NEXT_PUBLIC_DASHBOARD_ENV=production
NEXT_PUBLIC_DASHBOARD_PROJECT_LABEL=project
NEXT_PUBLIC_RAZORPAY_KEY_ID=__SET_IN_SECRET_MANAGER__

# Optional server-side project fallback for local single-project smoke/testing only.
# The customer dashboard proxy never forwards ZROKY_API_KEY; use browser session cookies for dashboard traffic.
# ZROKY_PROJECT_ID=__SET_IN_SECRET_MANAGER__

# Optional client-visible login controls.
# NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=true

# Optional server-side proxy tuning.
# ZROKY_API_PROXY_TIMEOUT_MS=30000
