# ──────────────────────────────────────────────────────────────────────────────
#  Zroky AI — Root .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Large binaries & installers ───────────────────────────────────────────────
*.exe
*.war
*.zip
*.dmg
*.pkg
*.msi
*.AppImage
*.iso

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/
*.whl

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
.secrets/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.pnp.*
*.tsbuildinfo

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.pytest_tmp/
.pytest-tmp/
.pytest_*/
pytest_temp_privacy2/
.coverage
coverage.xml
htmlcov/
coverage/
**/coverage/
.hypothesis/
*.cover
test_results.txt
lint_output.txt

# ── Linting / Type checking ───────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.dmypy.json
.pytype/

# ── IDE / Editors ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.codex/
.codex-logs/
codex-logs/
.agents/
.windsurf/
.claude/
.devin/
.kiro/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Temp / AI assistant artifacts ─────────────────────────────────────────────
claude-mem/
claude-code-page.md
claude-code-readme.txt
claude-code-snapshot.txt
docfx_temp/
.playwright-mcp/
.gocache/
**/.gocache/
.data/

# Generated QA / Codex artifacts
.tmp/
.worktrees/
/artifacts/
/dashboard-screenshot.png
**/playwright-report/
/zroky-dashboard/.codex-artifacts/
/zroky-dashboard/artifacts/
/zroky-landing/.codex-artifacts/

# ── Database ──────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
