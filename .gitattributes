# ──────────────────────────────────────────────────────────────────────────────
#  Zroky AI — .gitattributes
#  Ensures consistent line endings across Windows / macOS / Linux
# ──────────────────────────────────────────────────────────────────────────────

# Default: normalize all text files to LF in repo
* text=auto eol=lf

# Explicitly LF
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.sh        text eol=lf
*.env*      text eol=lf
*.txt       text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.sql       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
Dockerfile* text eol=lf

# Binary — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.exe       binary
*.war       binary
*.db        binary
*.sqlite    binary
*.sqlite3   binary
