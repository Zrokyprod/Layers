{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.zroky.ai/schemas/ingest-event/v2.json",
  "title": "IngestEvent",
  "description": "Canonical schema for a single AI call event ingested by Zroky. v2 adds multi-agent tracking fields (session_id, workflow_id, step_index, agent_framework). All v1 fields preserved for backward compatibility. DO NOT edit this file by hand — it is the single source of truth (Rule 1). Downstream artifacts (Pydantic model, TypeScript types, OTel mapping) are generated from it via scripts/gen_from_schema.py.",
  "type": "object",
  "required": ["call_id"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v2",
      "default": "v2",
      "description": "Schema version tag. Must be 'v2' for v2 events. Absence implies v1 (treated as v2-compatible)."
    },
    "call_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Unique identifier for this AI call. Set by the SDK before send.",
      "x-otel-attribute": "zroky.call.id"
    },
    "event_id": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "Optional idempotency key for deduplication.",
      "x-otel-attribute": "zroky.event.id"
    },
    "request_id": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "Provider-assigned request ID, if available.",
      "x-otel-attribute": "zroky.request.id"
    },
    "provider": {
      "type": "string",
      "default": "unknown",
      "minLength": 1,
      "maxLength": 120,
      "description": "AI provider name (e.g. 'openai', 'anthropic', 'google').",
      "x-otel-attribute": "gen_ai.system"
    },
    "model": {
      "type": "string",
      "default": "unknown",
      "minLength": 1,
      "maxLength": 120,
      "description": "Model identifier as returned by the provider (e.g. 'gpt-4o', 'claude-3-5-sonnet').",
      "x-otel-attribute": "gen_ai.response.model"
    },
    "call_type": {
      "type": "string",
      "default": "chat",
      "enum": ["chat", "completion", "embedding", "streaming", "image", "tts", "stt", "moderation", "function"],
      "description": "Type of AI call.",
      "x-otel-attribute": "zroky.call.type"
    },
    "status": {
      "type": "string",
      "default": "completed",
      "enum": ["completed", "error", "timeout", "cancelled", "rate_limited", "budget_blocked"],
      "description": "Outcome status of the call.",
      "x-otel-attribute": "zroky.call.status"
    },
    "latency_ms": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Wall-clock time from request send to response complete, in milliseconds.",
      "x-otel-attribute": "zroky.call.latency_ms"
    },
    "prompt_tokens": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "description": "Number of prompt/input tokens consumed.",
      "x-otel-attribute": "gen_ai.usage.input_tokens"
    },
    "estimated_prompt_tokens": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "SDK-estimated prompt token count (before provider confirmation).",
      "x-otel-attribute": "zroky.tokens.estimated_prompt"
    },
    "model_context_limit": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Total context window size of the model, in tokens.",
      "x-otel-attribute": "zroky.model.context_limit"
    },
    "model_context_limit_source": {
      "type": ["string", "null"],
      "maxLength": 64,
      "x-otel-attribute": "zroky.model.context_limit_source"
    },
    "model_context_limit_source_detail": {
      "type": ["string", "null"],
      "maxLength": 128
    },
    "model_context_limit_confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "model_context_limit_catalog_version": {
      "type": ["string", "null"],
      "maxLength": 64
    },
    "model_context_limit_catalog_updated_at": {
      "type": ["string", "null"],
      "maxLength": 32
    },
    "model_context_limit_catalog_stale": {
      "type": ["boolean", "null"]
    },
    "model_context_limit_catalog_stale_after_days": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "token_estimator_version": {
      "type": ["string", "null"],
      "maxLength": 64
    },
    "token_rules_version": {
      "type": ["string", "null"],
      "maxLength": 64
    },
    "completion_tokens": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "description": "Number of completion/output tokens generated.",
      "x-otel-attribute": "gen_ai.usage.output_tokens"
    },
    "reasoning_tokens": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "description": "Number of reasoning tokens (e.g. o1 thinking tokens).",
      "x-otel-attribute": "zroky.tokens.reasoning"
    },
    "cache_creation_tokens": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "x-otel-attribute": "zroky.tokens.cache_creation"
    },
    "cache_read_tokens": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "x-otel-attribute": "zroky.tokens.cache_read"
    },
    "estimated_cost_usd": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "SDK-estimated cost in USD.",
      "x-otel-attribute": "zroky.cost.estimated_usd"
    },
    "actual_cost_usd": {
      "type": ["number", "null"],
      "minimum": 0,
      "description": "Provider-billed cost in USD, if available.",
      "x-otel-attribute": "zroky.cost.actual_usd"
    },
    "budget_remaining_usd": {
      "type": ["number", "null"],
      "minimum": 0,
      "x-otel-attribute": "zroky.budget.remaining_usd"
    },
    "budget_action_taken": {
      "type": ["string", "null"],
      "maxLength": 64,
      "enum": ["none", "warn", "block", "soft_block", null],
      "x-otel-attribute": "zroky.budget.action"
    },
    "loop_action_taken": {
      "type": ["string", "null"],
      "maxLength": 64,
      "enum": ["none", "warn", "break", "abort", null],
      "x-otel-attribute": "zroky.loop.action"
    },
    "loop_call_count": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "x-otel-attribute": "zroky.loop.call_count"
    },
    "loop_cumulative_cost_usd": {
      "type": ["number", "null"],
      "minimum": 0,
      "x-otel-attribute": "zroky.loop.cumulative_cost_usd"
    },
    "exchange_rate_usd_to_inr": {
      "type": ["number", "null"],
      "exclusiveMinimum": 0
    },
    "exchange_rate_timestamp": {
      "oneOf": [{"type": "number"}, {"type": "string"}, {"type": "null"}]
    },
    "exchange_rate_source": {
      "type": ["string", "null"],
      "maxLength": 64
    },
    "tool_definitions": {
      "type": ["array", "null"],
      "items": {"type": "object"},
      "description": "Tool schemas available to the model for this call."
    },
    "tool_calls_made": {
      "type": ["array", "null"],
      "items": {"type": "object"},
      "description": "Tool invocations emitted by the model in this call."
    },
    "normalized_output": {
      "type": ["string", "null"],
      "maxLength": 4000,
      "description": "Normalized/cleaned model output (PII masked)."
    },
    "output_content": {
      "type": ["string", "null"],
      "maxLength": 4000,
      "description": "Raw model output content (PII masked)."
    },
    "output_fingerprint": {
      "type": ["string", "null"],
      "maxLength": 64,
      "description": "Stable hash of the output (excluding variable content).",
      "x-otel-attribute": "zroky.output.fingerprint"
    },
    "tool_lifecycle_summary": {
      "type": ["array", "null"],
      "items": {"type": "object"}
    },
    "retry_metadata": {
      "type": ["object", "null"]
    },
    "cache_hit": {
      "type": "boolean",
      "default": false,
      "x-otel-attribute": "zroky.cache.hit"
    },
    "timeout_triggered": {
      "type": "boolean",
      "default": false,
      "x-otel-attribute": "zroky.call.timeout_triggered"
    },
    "resolved_model": {
      "type": ["string", "null"],
      "maxLength": 120,
      "description": "Actual model used after fallback resolution, if different from 'model'.",
      "x-otel-attribute": "gen_ai.request.model"
    },
    "fallback_chain": {
      "type": ["array", "null"],
      "items": {"type": "string"},
      "description": "Ordered list of models tried before success."
    },
    "fallback_attempts": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "x-otel-attribute": "zroky.fallback.attempts"
    },
    "circuit_open_models": {
      "type": ["array", "null"],
      "items": {"type": "string"},
      "description": "Models whose circuit breakers were open at call time."
    },
    "trace_id": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "Distributed trace identifier (W3C traceparent format recommended).",
      "x-otel-attribute": "trace_id"
    },
    "parent_call_id": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "call_id of the parent call in a multi-agent tree.",
      "x-otel-attribute": "zroky.call.parent_id"
    },
    "agent_name": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "Logical name of the agent making this call.",
      "x-otel-attribute": "zroky.agent.name"
    },
    "prompt_fingerprint": {
      "type": ["string", "null"],
      "maxLength": 64,
      "description": "Stable hash of the prompt template (excluding variable/user content).",
      "x-otel-attribute": "zroky.prompt.fingerprint"
    },
    "user_id": {
      "type": ["string", "null"],
      "maxLength": 255,
      "x-otel-attribute": "enduser.id"
    },
    "is_synthetic": {
      "type": "boolean",
      "default": false,
      "description": "True for replay or test calls; excluded from cost aggregations.",
      "x-otel-attribute": "zroky.call.is_synthetic"
    },
    "is_production": {
      "type": ["boolean", "null"],
      "x-otel-attribute": "zroky.call.is_production"
    },
    "environment": {
      "type": ["string", "null"],
      "maxLength": 64,
      "description": "Runtime environment tag (e.g. 'production', 'staging', 'development').",
      "x-otel-attribute": "deployment.environment"
    },
    "metadata": {
      "type": ["object", "null"],
      "description": "Arbitrary key-value pairs for custom context. Not indexed.",
      "x-otel-attribute": "zroky.metadata"
    },
    "error_code": {
      "type": ["string", "null"],
      "maxLength": 120,
      "description": "Structured error/failure code (e.g. 'LOOP_DETECTED', 'BUDGET_EXCEEDED', 'CONTEXT_OVERFLOW').",
      "x-otel-attribute": "zroky.error.code"
    },
    "error_message": {
      "type": ["string", "null"],
      "maxLength": 4000,
      "x-otel-attribute": "zroky.error.message"
    },
    "failure_reason": {
      "type": ["object", "null"],
      "description": "Structured failure diagnostics set by the diagnosis engine."
    },
    "created_at": {
      "oneOf": [{"type": "number"}, {"type": "string"}, {"type": "null"}],
      "description": "Unix timestamp (float) or ISO-8601 string of when the call completed."
    },
    "session_id": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "[v2] Multi-turn session identifier. Groups calls within a single conversation.",
      "x-otel-attribute": "zroky.session.id"
    },
    "workflow_id": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "[v2] Parent workflow or pipeline run identifier. Groups calls across agent steps.",
      "x-otel-attribute": "zroky.workflow.id"
    },
    "step_index": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "[v2] Zero-based step position within a workflow. Used for ordering and cross-step loop detection.",
      "x-otel-attribute": "zroky.workflow.step_index"
    },
    "agent_framework": {
      "type": ["string", "null"],
      "maxLength": 64,
      "enum": ["langgraph", "crewai", "autogen", "llamaindex", "langchain", "custom", null],
      "description": "[v2] Agent orchestration framework, if known.",
      "x-otel-attribute": "zroky.agent.framework"
    }
  }
}
