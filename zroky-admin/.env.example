# Must point at the owner-enabled backend deployment (FEATURE_LEGACY_OWNER=true).
ZROKY_API_BASE_URL=https://zroky-api-admin.up.railway.app
NEXT_PUBLIC_DASHBOARD_ENV=owner
NEXT_PUBLIC_DASHBOARD_PROJECT_LABEL=owner
ZROKY_API_PROXY_TIMEOUT_MS=10000

# Do not set owner credentials in this app's environment.
# The operator enters the owner token in the browser gate; /api/owner/session
# stores it as an HttpOnly cookie and the proxy converts that cookie to the
# backend x-zroky-admin-token header server-side.
# ZROKY_OWNER_SESSION_MAX_AGE_SECONDS=28800
